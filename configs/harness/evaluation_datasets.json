{
  "schema_version": 1,
  "project": "orin-nx-eis",
  "purpose": "Lifecycle dataset registry for Orin NX EIS evaluation. This registry separates main quality evidence, challenge/failure-boundary evidence, diagnostic intent/foreground evidence, performance evidence, and future metric-calibration data.",
  "storage_policy": {
    "large_media_roots": [
      "data/raw",
      "data/sources",
      "results"
    ],
    "do_not_commit_large_media_by_default": true,
    "review_copy_root": "C:/Users/Admin/Videos/orin nx",
    "source_archives_root": "data/sources/NUS_raw_zips",
    "source_extracted_root": "data/sources/NUS_extracted"
  },
  "principles": [
    "Main quality claims come from core regression sets, not challenge sets.",
    "Challenge sets expose model boundaries and degradation behavior.",
    "Diagnostic sets answer why a method failed; they do not define headline pass rate.",
    "Metric-calibration datasets validate metrics, not EIS quality directly.",
    "Datasets may be redundant, but claim boundaries must remain separate."
  ],
  "datasets": [
    {
      "id": "nus_regular_gate_v1",
      "family": "NUS/SIGGRAPH2013",
      "category": "Regular",
      "role": "main_gate",
