      "priority": "P0",
      "source_url": "http://liushuaicheng.org/SIGGRAPH2013/data/Regular.zip",
      "source_archive": "data/sources/NUS_raw_zips/Regular.zip",
      "source_extracted_dir": "data/sources/NUS_extracted/Regular",
      "prepared_dir": "results/nus_regular_gate_v1",
      "raw_dir": "results/nus_regular_gate_v1/raw_clips",
      "stable_reference_dir": "results/nus_regular_gate_v1/stable_reference",
      "manifest": "results/nus_regular_gate_v1/nus_gate_manifest.csv",
      "metadata": "results/nus_regular_gate_v1/nus_gate_metadata.csv",
      "expected_prepared_clips": [
        "regular_gate01_regular_10",
        "regular_gate02_regular_19",
        "regular_gate03_regular_13",
        "regular_gate04_regular_8",
        "regular_gate05_regular_6"
